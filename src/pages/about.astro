---
import Layout from '../layouts/Layout.astro';
import { SITE_CONFIG } from '../config';
---

<Layout title={`About - ${SITE_CONFIG.title}`}>
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <h1 class="text-3xl font-bold text-center uppercase text-gray-600 dark:text-gray-400 mb-6">
      About me
    </h1>

    <!-- Icon Divider -->
    <div class="divider-custom">
      <div class="divider-custom-line"></div>
      <div class="divider-custom-icon">
        <svg
          width="0.5em"
          height="0.5em"
          viewBox="0 0 16 16"
          fill="currentColor"
          xmlns="http://www.w3.org/2000/svg"
        >
          <path
            d="M3.612 15.443c-.386.198-.824-.149-.746-.592l.83-4.73L.173 6.765c-.329-.314-.158-.888.283-.95l4.898-.696L7.538.792c.197-.39.73-.39.927 0l2.184 4.327 4.898.696c.441.062.612.636.283.95l-3.523 3.356.83 4.73c.078.443-.36.79-.746.592L8 13.187l-4.389 2.256z"
          />
        </svg>
      </div>
      <div class="divider-custom-line"></div>
    </div>

    <div class="flex flex-col items-center text-gray-600 dark:text-gray-400 mt-8">
      <div class="w-full space-y-6 text-gray-700 dark:text-gray-300 leading-relaxed">
        <p>
          Welcome! I'm a tech enthusiast passionate about continuous learning and community building. I attend local tech meetups and conferences to stay on the bleeding edge of software development, and this blog is my public notebook.
        </p>
        <p>
          Here, I translate meetup discussions, tech talks, and networking insights into actionable guides and overviews. If you want to level up your dev skills without sitting through a two-hour conference—or if you just want to know what the local tech scene is talking about this month—you're in the right place.
        </p>
        <div class="flex flex-wrap gap-6 mt-8">
          <a
            href="https://github.com/GJvignesh"
            target="_blank"
            rel="noopener noreferrer"
            class="text-blue-600 dark:text-blue-400 hover:underline font-semibold"
          >
            → GitHub
          </a>
          <a
            href="https://www.linkedin.com/in/vigneshgj/"
            target="_blank"
            rel="noopener noreferrer"
            class="text-blue-600 dark:text-blue-400 hover:underline font-semibold"
          >
            → LinkedIn
          </a>
        </div>
      </div>
    </div>
  </div>
</Layout>
